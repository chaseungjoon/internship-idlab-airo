<?xml version="1.0"?>
<robot name="pipette">

    <link name="base_link"/>
    <!-- Cylinder 1 -->
    <link name="cylinder1">
        <visual>
            <geometry>
                <cylinder radius="0.031" length="0.011"/>
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.031" length="0.011"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <!-- Cylinder 2 -->
    <link name="cylinder2">
        <visual>
            <geometry>
                <cylinder radius="0.0035" length="0.039"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0035" length="0.039"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <origin xyz="0 0 0.025"/>
            <inertia ixx="0.00005" iyy="0.00005" izz="0.00005" ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <joint name="base_link_joint" type="fixed">
        <parent link="base_link"/>
        <child link="cylinder1"/>
    </joint>
    <!-- Joint connecting the two cylinders -->
    <joint name="cylinder_1_to_cylinder_2" type="fixed">
        <parent link="cylinder1"/>
        <child link="cylinder2"/>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </joint>

</robot>
